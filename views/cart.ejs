<%- include('./partials/header') %>
    <div class="w-full min-h-screen flex items-start px-20 py-20 gap-10">
        <div class="w-[30%] rounded-md overflow-hidden border border-gray-200 bg-white shadow-sm">
            <% if (cart && cart.length > 0) { %>
                <div class="max-h-[600px] overflow-y-auto">
                    <% cart.forEach(function(item){ %>
                        <div class="border-b border-gray-200 p-4">
                            <div class="w-full h-40 bg-yellow-500 flex items-center justify-center mb-3">
                                <span class="text-white text-xl font-semibold"><%= item.name.charAt(0) %></span>
                            </div>
                            <div class="w-full flex justify-between items-center mb-2">
                                <h3 class="text-lg font-semibold"><%= item.name %></h3>
                            </div>
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-gray-600">Quantity: <%= item.quantity %></span>
                                <span class="font-semibold">₹ <%= item.price * item.quantity %></span>
                            </div>
                            <div class="flex items-center gap-2 mt-2">
                                <a href="/cart/update/<%= item.productId %>/decrease" class="px-2 py-1 bg-gray-500 text-white rounded text-sm">-</a>
                                <a href="/cart/update/<%= item.productId %>/increase" class="px-2 py-1 bg-blue-500 text-white rounded text-sm">+</a>
                                <a href="/cart/remove/<%= item.productId %>" class="px-2 py-1 bg-red-500 text-white rounded text-sm">Remove</a>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="w-full h-80 flex items-center justify-center bg-gray-100">
                    <p class="text-gray-600">Your cart is empty. <a href="/shop" class="text-blue-500 underline">Start shopping</a></p>
                </div>
            <% } %>
        </div>
        <div class="w-[70%]">
            <h3 class="text-xl">Price Breakdown</h3>
            <div class="px-10 mt-5">
                <div class="flex mt-2">
                    <h4 class="w-1/3">Total MRP</h4>
                    <h4>₹ <%= subtotal %></h4>
                </div>
                <div class="flex mt-2">
                    <h4 class="w-1/3">Discount on MRP</h4>
                    <h4>₹ 0</h4>
                </div>
                <div class="flex mt-2">
                    <h4 class="w-1/3">Platform Fee</h4>
                    <h4>₹ <%= platformFee %></h4>
                </div>
                <div class="flex mt-2">
                    <h4 class="w-1/3">Shipping Fee</h4>
                    <h4><%= shippingFee === 0 ? "FREE" : "₹ " + shippingFee %></h4>
                </div>
            </div>
            <div class="w-full h-[1px] bg-black mt-10"></div>
            <div class="flex mt-5">
                <h3 class="w-1/3 text-xl">Total Amount</h3>
                <h3 class="font-semibold text-xl text-green-600">₹ <%= total %></h3>
            </div>
            <form action="" class="mt-6">
                <button type="button"
                        class="px-6 py-3 bg-blue-600 text-white rounded-full hover:bg-blue-700 transition">
                    Checkout (Demo)
                </button>
            </form>
        </div>
    </div>
    <%- include('./partials/footer') %>