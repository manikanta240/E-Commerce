<%- include('./partials/header') %>
    <div class="w-full h-screen flex items-start px-20 py-20">
        <div class="w-[25%] flex h-screen flex-col items-start">
            <div class="flex flex-col">
                <a class="block w-fit mb-2" href="/products/admin">All Products</a>
                <a class="block w-fit mb-2" href="/products/create">Create new product</a>
            </div>
        </div>
        <div class="w-[75%] flex flex-col gap-5 h-screen">
            <a class="text-red-500 mb-4" href="javascript:void(0)">Delete all (demo)</a>
            <div class="flex flex-wrap items-start gap-5">
                <% if (products && products.length > 0) { %>
                    <% products.forEach(function(product){ %>
                        <div class="w-60 bg-red-500 rounded overflow-hidden">
                            <div class="w-full h-52 bg-yellow-500 flex items-center justify-center">
                                <% if (product.image) { %>
                                    <img class="h-[12rem]" src="data:image/jpeg;base64,<%= product.image.toString('base64') %>" alt="<%= product.name %>">
                                <% } else { %>
                                    <span class="text-white text-sm">No image</span>
                                <% } %>
                            </div>
                            <div class="flex justify-between items-center px-4 py-4 bg-white text-black">
                                <div>
                                    <h3><%= product.name %></h3>
                                    <h4>₹ <%= product.price %></h4>
                                </div>
                                <a class="w-7 h-7 flex items-center justify-center rounded-full bg-red-500 text-white" href="/cart/add/<%= product._id %>">
                                    <i class="ri-add-line"></i>
                                </a>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p class="text-gray-600">No products created yet.</p>
                <% } %>
            </div>
        </div>
    </div>
    <%- include('./partials/footer') %>